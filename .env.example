# ─── Backend ───────────────────────────────────────────────
# Perfil ativo do Spring Boot: dev | prod
SPRING_PROFILES_ACTIVE=dev

# Dev (MySQL) — usado quando SPRING_PROFILES_ACTIVE=dev
DB_HOST=localhost
DB_PORT=3306
DB_NAME=sistema_produtos
DB_USERNAME=root
DB_PASSWORD=sua_senha_aqui

# Prod (PostgreSQL) — usado quando SPRING_PROFILES_ACTIVE=prod
DATABASE_URL=jdbc:postgresql://<host>:<port>/<database>
DATABASE_USERNAME=seu_usuario
DATABASE_PASSWORD=sua_senha_aqui

# ─── Frontend ──────────────────────────────────────────────
# URL base da API consumida pelo React (Vite expõe variáveis VITE_*)
VITE_API_URL=http://localhost:8080
